DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
AUTH_SECRET="replace-with-auth-secret"
AUTH_URL="http://localhost:3000"
SITE_ACCESS_CODE="replace-with-site-access-code"
ADMIN_EMAILS="you@example.com"
OPENAI_API_KEY="replace-with-openai-key"
OPENAI_MODEL="gpt-4.1-mini"
RESEND_API_KEY="replace-with-resend-key"
EMAIL_FROM="Medical AI <noreply@example.com>"
CONTACT_TO_EMAIL="you@example.com"
NEXT_PUBLIC_SITE_URL="https://www.medical-ai.nl"
KV_REST_API_URL="https://your-kv-instance.upstash.io"
KV_REST_API_TOKEN="replace-with-kv-token"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"

# Never add secrets with NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_* variables are bundled into client-side JavaScript.
