// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String   @id @default(cuid())
  pubmedId    String   @unique
  title       String
  abstract    String
  authors     String?
  journal     String?
  pubDate     DateTime?
  url         String?
  status      String   @default("FETCHED") // FETCHED, SELECTED, REJECTED, PUBLISHED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  blogPost    BlogPost?
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  content     String   // Markdown content
  summary     String?
  category    String   // Predictie, Diagnostiek, Methodisch, Ethiek
  isGuideline Boolean  @default(false)
  imageUrl    String?
  published   Boolean  @default(false)
  scheduledFor DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  articleId   String   @unique
  article     Article  @relation(fields: [articleId], references: [id])
  likes       Like[]
  comments    Comment[]

  // Blog 2.0 Fields
  specialism  String?  // Comma-separated for multiple values
  ceStatus    String?
  cost        String?
  modelType   String?
  doi         String?
  citation    String?
  developer   String?
  privacy     String?  // Deprecated in favor of privacyType? Or keep as custom text?
  privacyType String?  // Cloud, On-Premise, Hybrid
  integration String?
  demoUrl     String?
  vendorUrl   String?
  fdaStatus   String?
  fdaNumber   String?

  tags        Tag[]

  // Guidelines & Display Settings
  coverImage        String?
  guidelineCategory String? // "Klinisch onderzoek...", "Nederlandse regelgeving", etc.
  displayLocations  String[] // "Homepage", "Publicaties", "Guidelines"
}

model Tag {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model User {
  id        String        @id @default(cuid())
  name      String
  email     String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sessions  UserSession[]
  magicLinks MagicLinkToken[]
  likes     Like[]
  comments  Comment[]
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MagicLinkToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  email      String
  name       String?
  redirectTo String?
  userId     String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expiresAt])
  @@index([userId])
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  blogPostId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([userId, blogPostId])
  @@index([blogPostId])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  userId     String
  blogPostId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([blogPostId, createdAt])
  @@index([userId])
}
